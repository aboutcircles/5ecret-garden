# Root ignore for 5ecret-garden monorepo

# Dependencies
node_modules/
**/node_modules/

# Builds and artifacts
/build/
**/build/
dist/
**/dist/
/.svelte-kit/
**/.svelte-kit/
/.turbo/
**/.turbo/
coverage/
**/coverage/

# Env files (keep examples)
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Logs
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
**/logs/

# OS/editor files
.DS_Store
*.swp
.idea/
.vscode/

# Package manager caches
.pnpm-store/
**/.pnpm-store/

# SvelteKit/Vite timestamp files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Do NOT ignore lockfiles; they should be committed
# (package-lock.json, yarn.lock, pnpm-lock.yaml)
test-results/
