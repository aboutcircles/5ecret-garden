{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@circles-market/core": ["../circles-market-core/src/index.ts"],
      "@circles-market/session": ["../circles-market-session/src/index.ts"],
      "@circles-market/signers": ["../circles-market-signers/src/index.ts"],
      "@circles-market/auth": ["../circles-market-auth/src/index.ts"],
      "@circles-market/orders": ["../circles-market-orders/src/index.ts"],
      "@circles-market/cart": ["../circles-market-cart/src/index.ts"],
      "@circles-market/offers": ["../circles-market-offers/src/index.ts"],
      "@circles-market/sales": ["../circles-market-sales/src/index.ts"],
      "@circles-market/catalog": ["../circles-market-catalog/src/index.ts"],
      "@circles-profile/core": ["../circles-profile-core/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
