yarn-error.log*
pnpm-debug.log*
*.log

# Env files (local only)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editors and OS files
.DS_Store
.idea/
.vscode/
Thumbs.db

# Misc temp
/tmp/
/temp/
